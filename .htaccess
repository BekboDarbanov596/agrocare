Options -Indexes
Options +FollowSymLinks

# ========================
# REWRITE ENGINE
# ========================
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Защита от прямого доступа к .env
    RewriteRule ^\.env - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]

    # Статические файлы отдаём напрямую
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Всё остальное → index.php (Front Controller)
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# ========================
# ЗАЩИТА ЧУВСТВИТЕЛЬНЫХ ФАЙЛОВ
# ========================
<FilesMatch "\.(env|bak|log|sql|sh)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<Files "composer.json">
    Order allow,deny
    Deny from all
</Files>

<Files "composer.lock">
    Order allow,deny
    Deny from all
</Files>

# ========================
# GZIP СЖАТИЕ (экономит трафик)
# ========================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ========================
# КЭШИРОВАНИЕ СТАТИКИ
# ========================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ========================
# PHP НАСТРОЙКИ (если shared hosting)
# ========================
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 20M
    php_value post_max_size 20M
    php_value max_execution_time 60
</IfModule>
